generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEADERSHIP
  OPS_MANAGER
  BRANCH_MANAGER
  RECOVERY_MANAGER
  CLAIMS_MANAGER
  SALES_MANAGER
  FLEET_MANAGER
  FINANCE_MANAGER
  CLAIMS_TEAM_IN
  CLAIMS_TEAM_OUT
  CLAIMS_TEAM_LIABILITY
  CSE_DRIVER
  SALES_REP
  RECOVERY_AGENT
  FLEET_COORDINATOR
}

enum VehicleStatus {
  AVAILABLE
  BOOKED_FOR_REPAIR
  BOOKED_FOR_SERVICE
  CLEAN_NEEDED
  IN_REPAIR
  IN_SERVICE
  NOT_AVAILABLE
  ON_HIRE
  RESERVED_FOR_TRANSPORT
  RETIRED
  WITH_STAFF
}

enum ReservationStatus {
  DRAFT
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ClaimStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum JobType {
  DELIVERY
  RETURN
  EXCHANGE
  IN_PROGRESS
  DOCU_RESIGN
}

enum DeliveryStatus {
  SCHEDULED
  DISPATCHED
  EN_ROUTE
  DELIVERED
  FAILED
}

model User {
  id         String     @id @default(cuid())
  clerkId    String     @unique
  email      String     @unique
  firstName  String
  lastName   String
  role       Role       @default(CSE_DRIVER)
  branch     Branch?    @relation(fields: [branchId], references: [id])
  branchId   String?
  deliveries Delivery[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Branch {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  address   String
  suburb    String?
  postcode  String?
  state     String?
  phone     String?
  users     User[]
  vehicles  Vehicle[]
  repairers Repairer[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Vehicle {
  id           String         @id @default(cuid())
  registration String         @unique
  make         String
  model        String
  year         Int
  colour       String
  state        String         @default("")
  category     String
  status       VehicleStatus  @default(AVAILABLE)
  branch       Branch?        @relation(fields: [branchId], references: [id])
  branchId     String?
  reservations Reservation[]
  photos       VehiclePhoto[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Customer {
  id            String        @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String
  licenceNumber String?
  reservations  Reservation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Insurer {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  phone     String?
  email     String?
  address   String?
  claims    Claim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repairer {
  id               String             @id @default(cuid())
  name             String
  phone            String
  email            String?
  address          String
  suburb           String
  postcode         String?
  state            String?
  territory        String?
  branch           Branch?            @relation(fields: [branchId], references: [id])
  branchId         String?
  paymentType      String?
  bsb              String?
  accountNumber    String?
  accountName      String?
  bankName         String?
  referralAmount   Decimal?
  paymentFrequency String?
  claims           Claim[]
  documents        RepairerDocument[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model RepairerDocument {
  id          String   @id @default(cuid())
  repairer    Repairer @relation(fields: [repairerId], references: [id])
  repairerId  String
  name        String
  fileData    String   // base64
  mimeType    String
  createdAt   DateTime @default(now())
}

model Reservation {
  id                  String             @id @default(cuid())
  reservationNumber   String             @unique @default("")
  fileNumber          String?            @unique
  customer            Customer           @relation(fields: [customerId], references: [id])
  customerId          String
  vehicle             Vehicle?           @relation(fields: [vehicleId], references: [id])
  vehicleId           String?
  startDate           DateTime
  endDate             DateTime?
  status              ReservationStatus  @default(PENDING)
  claim               Claim?
  delivery            Delivery?
  paymentCards        PaymentCard[]
  additionalDrivers   AdditionalDriver[]
  reservationNotes    ReservationNote[]
  signature           SignatureRecord?
  payments            Payment[]
  cancellationReason  String?
  cancellationComment String?
  sourceOfBusiness    String?
  licencePhotoUrl     String?
  partnerName         String?

  // Accident & Claims fields
  typeOfCover        String?
  hireType           String?
  towIn              String?
  totalLoss          String?
  settlementReceived String?
  repairStartDate    DateTime?
  repairEndDate      DateTime?
  estimateDate       DateTime?
  assessmentDate     DateTime?
  repairerInvoiceNo  String?
  repairerInvoiceAmt Decimal?
  thirdPartyRecovery String?
  witnessName        String?
  witnessPhone       String?
  policeContactName  String?
  policePhone        String?
  policeEventNo      String?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}
model Claim {
  id               String      @id @default(cuid())
  reservation      Reservation @relation(fields: [reservationId], references: [id])
  reservationId    String      @unique
  insurer          Insurer?    @relation(fields: [insurerId], references: [id])
  insurerId        String?
  repairer         Repairer?   @relation(fields: [repairerId], references: [id])
  repairerId       String?
  claimNumber      String?     @unique
  claimReference   String?
  sourceOfBusiness String?
  claimHandlerId   String?
  status           ClaimStatus @default(OPEN)
  notes            ClaimNote[]
  documents        Document[]
  invoices         Invoice[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model ClaimNote {
  id         String   @id @default(cuid())
  claim      Claim    @relation(fields: [claimId], references: [id])
  claimId    String
  note       String
  authorName String
  createdAt  DateTime @default(now())
}

model Document {
  id        String   @id @default(cuid())
  claim     Claim    @relation(fields: [claimId], references: [id])
  claimId   String
  name      String
  url       String
  type      String
  createdAt DateTime @default(now())
}

model Invoice {
  id        String    @id @default(cuid())
  claim     Claim     @relation(fields: [claimId], references: [id])
  claimId   String
  amount    Float
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Delivery {
  id            String         @id @default(cuid())
  reservation   Reservation    @relation(fields: [reservationId], references: [id])
  reservationId String         @unique
  driver        User?          @relation(fields: [driverId], references: [id])
  driverId      String?
  address       String
  suburb        String
  scheduledAt   DateTime
  deliveredAt   DateTime?
  status        DeliveryStatus @default(SCHEDULED)
  jobType       JobType        @default(DELIVERY)
  notes         String?
  createdAt     DateTime       @default(now())
  photos        DeliveryPhoto[]
  updatedAt     DateTime       @updatedAt
}

model ReservationNote {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  note          String
  authorName    String
  createdAt     DateTime    @default(now())
}

model FileNumberCounter {
  id  Int @id @default(1)
  KPK Int @default(1000)
  COB Int @default(1000)
}

model ReservationCounter {
  id      Int @id @default(1)
  current Int @default(1000)
}

model PaymentCard {
  id             String      @id @default(cuid())
  referenceCode  String      @unique @default("")
  reservation    Reservation @relation(fields: [reservationId], references: [id])
  reservationId  String
  cardType       String
  cardNumber     String
  expiryDate     String
  cardholderName String
  createdAt      DateTime    @default(now())
}

model AdditionalDriver {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  firstName     String
  lastName      String
  licenceNumber String
  licenceExpiry String?
  dob           String?
  phone         String?
  createdAt     DateTime    @default(now())
}

model DeliveryPhoto {
  id         String   @id @default(cuid())
  delivery   Delivery @relation(fields: [deliveryId], references: [id])
  deliveryId String
  url        String
  key        String
  caption    String?
  createdAt  DateTime @default(now())
}

model ChargeType {
  id            String   @id @default(cuid())
  name          String   @unique
  defaultAmount Float?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Payment {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  chargeType    String
  description   String?
  amount        Float
  status        String      @default("PENDING")
  method        String?
  cardReference String?
  processedAt   DateTime?
  processedBy   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model DocumentTemplate {
  id         String   @id @default(cuid())
  type       String   @unique
  name       String
  url        String
  key        String
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SignatureRecord {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String      @unique
  signatureData String
  signedAt      DateTime    @default(now())
  signingMethod String
  ipAddress     String?
}

model VehiclePhoto {
  id        String   @id @default(cuid())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId String
  url       String
  key       String
  caption   String?
  createdAt DateTime @default(now())
}