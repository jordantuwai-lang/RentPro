generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPS_MANAGER
  BDM
  DRIVER
  REPAIRER
}

enum BranchCode {
  KPK
  COB
}

enum VehicleStatus {
  AVAILABLE
  ON_HIRE
  IN_MAINTENANCE
  AWAITING_REPAIR
  RETIRED
}

enum ReservationStatus {
  DRAFT
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ClaimStatus {
  OPEN
  PENDING_APPROVAL
  APPROVED
  INVOICED
  CLOSED
  DISPUTED
}

enum DeliveryStatus {
  SCHEDULED
  DISPATCHED
  EN_ROUTE
  DELIVERED
  FAILED
}

model User {
  id         String     @id @default(cuid())
  clerkId    String     @unique
  email      String     @unique
  firstName  String
  lastName   String
  role       Role       @default(DRIVER)
  branch     Branch?    @relation(fields: [branchId], references: [id])
  branchId   String?
  deliveries Delivery[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Branch {
  id        String     @id @default(cuid())
  name      String
  code      BranchCode @unique
  address   String
  phone     String
  users     User[]
  vehicles  Vehicle[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Vehicle {
  id           String        @id @default(cuid())
  registration String        @unique
  make         String
  model        String
  year         Int
  colour       String
  category     String
  status       VehicleStatus @default(AVAILABLE)
  branch       Branch        @relation(fields: [branchId], references: [id])
  branchId     String
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Customer {
  id            String        @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String
  licenceNumber String?
  reservations  Reservation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Insurer {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  phone     String?
  email     String?
  address   String?
  claims    Claim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repairer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String
  suburb    String
  territory String?
  claims    Claim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reservation {
  id         String            @id @default(cuid())
reservationNumber String            @unique @default("")
  customer   Customer          @relation(fields: [customerId], references: [id])
  customerId String
  vehicle    Vehicle           @relation(fields: [vehicleId], references: [id])
  vehicleId  String
  startDate  DateTime
  endDate    DateTime?
  status     ReservationStatus @default(PENDING)
  claim      Claim?
  delivery   Delivery?
paymentCards     PaymentCard[]
additionalDrivers AdditionalDriver[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model Claim {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String      @unique
  insurer       Insurer     @relation(fields: [insurerId], references: [id])
  insurerId     String
  repairer      Repairer?   @relation(fields: [repairerId], references: [id])
  repairerId    String?
  claimNumber   String?
  status        ClaimStatus @default(OPEN)
  documents     Document[]
  invoices      Invoice[]
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  claim     Claim    @relation(fields: [claimId], references: [id])
  claimId   String
  name      String
  url       String
  type      String
  createdAt DateTime @default(now())
}

model Invoice {
  id        String    @id @default(cuid())
  claim     Claim     @relation(fields: [claimId], references: [id])
  claimId   String
  amount    Float
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Delivery {
  id            String         @id @default(cuid())
  reservation   Reservation    @relation(fields: [reservationId], references: [id])
  reservationId String         @unique
  driver        User           @relation(fields: [driverId], references: [id])
  driverId      String
  address       String
  suburb        String
  scheduledAt   DateTime
  deliveredAt   DateTime?
  status        DeliveryStatus @default(SCHEDULED)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ReservationCounter {
  id      Int @id @default(1)
  current Int @default(1000)
}

model PaymentCard {
  id            String      @id @default(cuid())
referenceCode String      @unique @default("")
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  cardType      String
  cardNumber    String
  expiryDate    String
  cardholderName String
  createdAt     DateTime    @default(now())
}

model AdditionalDriver {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  firstName     String
  lastName      String
  licenceNumber String
  licenceExpiry String?
  dob           String?
  phone         String?
  createdAt     DateTime    @default(now())
}
