// ============================================================
// RentPro — Prisma Schema
// Updated: Claim model expanded with child models.
// AccidentDetails, AtFaultParty, RepairDetails broken out
// from Reservation. Document renamed to ClaimDocument.
// New enums: LiabilityStatus, TypeOfCover, HireType.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  LEADERSHIP
  OPS_MANAGER
  BRANCH_MANAGER
  RECOVERY_MANAGER
  CLAIMS_MANAGER
  SALES_MANAGER
  FLEET_MANAGER
  FINANCE_MANAGER
  CLAIMS_TEAM_IN
  CLAIMS_TEAM_OUT
  CLAIMS_TEAM_LIABILITY
  CSE_DRIVER
  SALES_REP
  RECOVERY_AGENT
  FLEET_COORDINATOR
}

enum VehicleStatus {
  AVAILABLE
  BOOKED_FOR_REPAIR
  BOOKED_FOR_SERVICE
  CLEAN_NEEDED
  IN_REPAIR
  IN_SERVICE
  NOT_AVAILABLE
  ON_HIRE
  RESERVED_FOR_TRANSPORT
  RETIRED
  WITH_STAFF
}

enum ReservationStatus {
  DRAFT
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ClaimStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

// Who is responsible for the accident
enum LiabilityStatus {
  PENDING
  ACCEPTED
  DISPUTED
  DENIED
}

// The type of insurance cover the NAF (not-at-fault) driver holds
enum TypeOfCover {
  CTP
  TPP
  COMP
}

// Whether the hire is billed to the insurer (credit) or the customer directly
enum HireType {
  CREDIT_HIRE
  DIRECT_HIRE
}

enum JobType {
  DELIVERY
  RETURN
  EXCHANGE
  IN_PROGRESS
  DOCU_RESIGN
}

enum DeliveryStatus {
  SCHEDULED
  DISPATCHED
  EN_ROUTE
  DELIVERED
  FAILED
}

// ─────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────

model User {
  id         String     @id @default(cuid())
  clerkId    String     @unique
  email      String     @unique
  firstName  String
  lastName   String
  role       Role       @default(CSE_DRIVER)
  branch     Branch?    @relation(fields: [branchId], references: [id])
  branchId   String?
  deliveries Delivery[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Branch {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  address   String
  suburb    String?
  postcode  String?
  state     String?
  phone     String?
  users     User[]
  vehicles  Vehicle[]
  repairers Repairer[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Vehicle {
  id           String        @id @default(cuid())
  registration String        @unique
  make         String
  model        String
  year         Int
  colour       String
  state        String        @default("")
  category     String
  status       VehicleStatus @default(AVAILABLE)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  branchId     String?
  reservations Reservation[]
  photos       VehiclePhoto[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Customer {
  id            String        @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String
  licenceNumber String?
  reservations  Reservation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Insurer {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  phone     String?
  email     String?
  address   String?
  claims    Claim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repairer {
  id               String             @id @default(cuid())
  name             String
  phone            String
  email            String?
  address          String
  suburb           String
  postcode         String?
  state            String?
  territory        String?
  branch           Branch?            @relation(fields: [branchId], references: [id])
  branchId         String?
  paymentType      String?
  bsb              String?
  accountNumber    String?
  accountName      String?
  bankName         String?
  referralAmount   Decimal?
  paymentFrequency String?
  claims           Claim[]
  documents        RepairerDocument[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model RepairerDocument {
  id         String   @id @default(cuid())
  repairer   Repairer @relation(fields: [repairerId], references: [id])
  repairerId String
  name       String
  fileData   String   // base64 encoded file content
  mimeType   String
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────
// RESERVATION
// Accident/claims fields removed — they now
// live on the Claim model and its children.
// ─────────────────────────────────────────

model Reservation {
  id                  String             @id @default(cuid())
  reservationNumber   String             @unique @default("")
  fileNumber          String?            @unique
  customer            Customer           @relation(fields: [customerId], references: [id])
  customerId          String
  vehicle             Vehicle?           @relation(fields: [vehicleId], references: [id])
  vehicleId           String?
  startDate           DateTime
  endDate             DateTime?
  status              ReservationStatus  @default(PENDING)
  cancellationReason  String?
  cancellationComment String?
  sourceOfBusiness    String?
  licencePhotoUrl     String?
  partnerName         String?

  // Relations
  claim             Claim?
  delivery          Delivery?
  paymentCards      PaymentCard[]
  additionalDrivers AdditionalDriver[]
  reservationNotes  ReservationNote[]
  signature         SignatureRecord?
  payments          Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// CLAIM
// The core claim record. Parent of all
// claim-related child models below.
// ─────────────────────────────────────────

model Claim {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String      @unique
  insurer       Insurer?    @relation(fields: [insurerId], references: [id])
  insurerId     String?
  repairer      Repairer?   @relation(fields: [repairerId], references: [id])
  repairerId    String?

  // Core claim identity
  claimNumber   String?  @unique
  claimReference String?
   sourceOfBusiness String?   // ← add this line

  // Claim handler at the insurer
  claimHandlerName  String?
  claimHandlerPhone String?
  claimHandlerEmail String?

  // Hire classification
  hireType    HireType?
  typeOfCover TypeOfCover?
  policyNumber String?
  excessAmount Decimal?

  // Liability
  liabilityStatus LiabilityStatus @default(PENDING)
  liabilityNotes  String?

  // Key flags
  totalLoss          Boolean @default(false)
  towIn              Boolean @default(false)
  settlementReceived Boolean @default(false)
  isDriverOwner      Boolean @default(true) // Is the NAF driver also the vehicle owner?

  // Lifecycle
  status ClaimStatus @default(OPEN)

  // Child models
  accidentDetails AccidentDetails?
  atFaultParty    AtFaultParty?
  repairDetails   RepairDetails?
  notes           ClaimNote[]
  documents       ClaimDocument[]
  invoices        Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// ACCIDENT DETAILS
// What happened, when, where, police, witnesses.
// Replaces the scattered fields that were on Reservation.
// ─────────────────────────────────────────

model AccidentDetails {
  id      String @id @default(cuid())
  claim   Claim  @relation(fields: [claimId], references: [id])
  claimId String @unique

  // Accident basics
  accidentDate        DateTime?
  accidentTime        String?
  accidentLocation    String?
  accidentDescription String?

  // Police
  policeAttended    Boolean @default(false)
  policeEventNo     String?
  policeStation     String?
  policeContactName String?
  policePhone       String?

  // Witnesses
  witnessName      String?
  witnessPhone     String?
  witnessStatement String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// AT FAULT PARTY
// The other driver involved in the accident.
// Modelled after TSD's "At Fault Third Party" modal.
// ─────────────────────────────────────────

model AtFaultParty {
  id      String @id @default(cuid())
  claim   Claim  @relation(fields: [claimId], references: [id])
  claimId String @unique

  // Identity
  firstName   String?
  lastName    String?
  phone       String?
  email       String?
  dateOfBirth String?

  // Address
  streetAddress String?
  suburb        String?
  state         String?
  postcode      String?

  // Licence
  licenceNumber String?
  licenceState  String?
  licenceExpiry String?

  // Their vehicle
  vehicleRego   String?
  vehicleMake   String?
  vehicleModel  String?
  vehicleYear   Int?
  vehicleColour String?

  // Their insurance (if known)
  theirInsurer  String?
  theirPolicyNo String?
  theirClaimNo  String?

  // Company details (if driving a business vehicle)
  companyName  String?
  companyABN   String?
  companyPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// REPAIR DETAILS
// Repair lifecycle tracking. Replaces repair
// fields that were scattered on Reservation.
// ─────────────────────────────────────────

model RepairDetails {
  id      String @id @default(cuid())
  claim   Claim  @relation(fields: [claimId], references: [id])
  claimId String @unique

  estimateDate     DateTime?
  assessmentDate   DateTime?
  repairStartDate  DateTime?
  repairEndDate    DateTime?
  invoiceNumber    String?
  invoiceAmount    Decimal?
  authorisedAmount Decimal?

  thirdPartyRecovery Boolean @default(false)
  recoveryAmount     Decimal?

  repairNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// CLAIM NOTES
// Internal notes against a claim (separate
// from ReservationNotes which are on the hire).
// ─────────────────────────────────────────

model ClaimNote {
  id         String   @id @default(cuid())
  claim      Claim    @relation(fields: [claimId], references: [id])
  claimId    String
  note       String
  authorName String
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────
// CLAIM DOCUMENTS
// Documents attached to a claim: police reports,
// repair authorities, photos, invoices, etc.
// Renamed from Document for clarity.
// ─────────────────────────────────────────

model ClaimDocument {
  id        String   @id @default(cuid())
  claim     Claim    @relation(fields: [claimId], references: [id])
  claimId   String
  name      String
  url       String
  // e.g. "POLICE_REPORT" | "REPAIR_AUTHORITY" | "PHOTO" | "INVOICE" | "OTHER"
  type      String
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// INVOICES
// Billing records attached to a claim.
// ─────────────────────────────────────────

model Invoice {
  id        String    @id @default(cuid())
  claim     Claim     @relation(fields: [claimId], references: [id])
  claimId   String
  amount    Float
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─────────────────────────────────────────
// DELIVERY / LOGISTICS
// ─────────────────────────────────────────

model Delivery {
  id            String         @id @default(cuid())
  reservation   Reservation    @relation(fields: [reservationId], references: [id])
  reservationId String         @unique
  driver        User?          @relation(fields: [driverId], references: [id])
  driverId      String?
  address       String
  suburb        String
  scheduledAt   DateTime
  deliveredAt   DateTime?
  status        DeliveryStatus @default(SCHEDULED)
  jobType       JobType        @default(DELIVERY)
  notes         String?
  photos        DeliveryPhoto[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DeliveryPhoto {
  id         String   @id @default(cuid())
  delivery   Delivery @relation(fields: [deliveryId], references: [id])
  deliveryId String
  url        String
  key        String
  caption    String?
  createdAt  DateTime @default(now())
}

// ─────────────────────────────────────────
// RESERVATION SUPPORT MODELS
// ─────────────────────────────────────────

model ReservationNote {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  note          String
  authorName    String
  createdAt     DateTime    @default(now())
}

model PaymentCard {
  id             String      @id @default(cuid())
  referenceCode  String      @unique @default("")
  reservation    Reservation @relation(fields: [reservationId], references: [id])
  reservationId  String
  cardType       String
  cardNumber     String
  expiryDate     String
  cardholderName String
  createdAt      DateTime    @default(now())
}

model AdditionalDriver {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  firstName     String
  lastName      String
  licenceNumber String
  licenceExpiry String?
  dob           String?
  phone         String?
  createdAt     DateTime    @default(now())
}

model Payment {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  chargeType    String
  description   String?
  amount        Float
  status        String      @default("PENDING")
  method        String?
  cardReference String?
  processedAt   DateTime?
  processedBy   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model SignatureRecord {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String      @unique
  signatureData String
  signedAt      DateTime    @default(now())
  signingMethod String
  ipAddress     String?
}

// ─────────────────────────────────────────
// FLEET SUPPORT MODELS
// ─────────────────────────────────────────

model VehiclePhoto {
  id        String   @id @default(cuid())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId String
  url       String
  key       String
  caption   String?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// ADMIN / CONFIG MODELS
// ─────────────────────────────────────────

model ChargeType {
  id            String   @id @default(cuid())
  name          String   @unique
  defaultAmount Float?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model DocumentTemplate {
  id         String   @id @default(cuid())
  type       String   @unique
  name       String
  url        String
  key        String
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FileNumberCounter {
  id  Int @id @default(1)
  KPK Int @default(1000)
  COB Int @default(1000)
}

model ReservationCounter {
  id      Int @id @default(1)
  current Int @default(1000)
}
